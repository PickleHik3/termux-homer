#!/data/data/com.termux/files/usr/bin/sh
set -eu

if [ "$#" != "0" ]; then
  echo "usage: termux-restart" >&2
  exit 2
fi

# Keep behavior aligned with tel-restart for launcher state cleanup when present.
if command -v tel-delete-status >/dev/null 2>&1; then
  tel-delete-status -1 || true
fi

# Preferred path: Shizuku-backed Tooie endpoint.
if command -v tooie >/dev/null 2>&1; then
  # Single `am start -S` avoids killing Tooie before a separate start call.
  RESTART_CMD='am start -S -n com.termux/.app.TermuxActivity'
  if tooie exec "$RESTART_CMD" >/dev/null 2>&1; then
    exit 0
  fi

  STATUS="$(tooie status 2>/dev/null || true)"
  case "$STATUS" in
    *'"execPolicy":{"enabled":false'*)
      echo "termux-restart: tooie exec is disabled by policy." >&2
      echo "Set ~/.tooie/config.json execEnabled=true and allow prefix: am start -S -n com.termux/.app.TermuxActivity" >&2
      exit 1
      ;;
  esac
fi

# Fallbacks for environments without Tooie/Shizuku availability.
if [ -x "$HOME/.rish/rish" ]; then
  exec "$HOME/.rish/rish" -c "am start -S -n com.termux/.app.TermuxActivity"
fi

echo "termux-restart: failed (Tooie endpoint unavailable and fallback paths failed)" >&2
exit 1
