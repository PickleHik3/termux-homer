#!/data/data/com.termux/files/usr/bin/sh
set -eu

print_help() {
  cat <<'EOF'
LauncherCtl CLI - local API client for Termux:Launcher Shizuku integration

Usage:
  launcherctl [command] [args]
  launcherctl help [command]

Commands:
  status                    Get backend/API status.
  apps                      List installed apps.
  resources                 Get system resource snapshot.
  media                     Get now-playing media info.
  art                       Get current media artwork metadata.
  notifications             Get active notifications snapshot.
  brightness [value]        Set or query screen brightness endpoint.
  volume [value] [stream]   Set or query volume endpoint.
  exec <command>            Run policy-allowed command via /v1/exec.
  permission                Request privileged backend permission.
  lock                      Lock screen.
  token rotate              Rotate LauncherCtl API auth token.

Examples:
  launcherctl status
  launcherctl apps
  launcherctl exec "id"
  launcherctl volume 8 3
  launcherctl brightness 120
  launcherctl permission

Config files:
  ~/.launcherctl/endpoint   Base URL (for example http://127.0.0.1:40851)
  ~/.launcherctl/token      Bearer token used by this client
  ~/.launcherctl/config.json
    - execEnabled: true/false
    - allowedCommandPrefixes: prefix allowlist for 'launcherctl exec'

Notes:
  - 'launcherctl exec' returns HTTP 403 if disabled by policy or prefix is not allowed.
  - Use: launcherctl help exec
EOF
}

print_exec_help() {
  cat <<'EOF'
Usage:
  launcherctl exec "<command>"

Description:
  Sends POST /v1/exec with JSON body {"command":"..."}.
  The command must match an allowed prefix in ~/.launcherctl/config.json.

Examples:
  launcherctl exec "id"
  launcherctl exec "pm list packages"
EOF
}

cmd="${1:-status}"

case "$cmd" in
  -h|--help|help)
    sub="${2:-}"
    case "$sub" in
      ""|all)
        print_help
        ;;
      exec)
        print_exec_help
        ;;
      *)
        echo "launcherctl: unknown help topic: $sub" >&2
        print_help >&2
        exit 2
        ;;
    esac
    exit 0
    ;;
esac

LAUNCHERCTL_DIR="$HOME/.launcherctl"
TOKEN_FILE="$LAUNCHERCTL_DIR/token"
ENDPOINT_FILE="$LAUNCHERCTL_DIR/endpoint"
if [ ! -r "$TOKEN_FILE" ] || [ ! -r "$ENDPOINT_FILE" ]; then
  echo "launcherctl: missing $TOKEN_FILE or $ENDPOINT_FILE" >&2
  echo "run: launcherctl --help" >&2
  exit 1
fi

TOKEN=$(cat "$TOKEN_FILE")
BASE=$(cat "$ENDPOINT_FILE")
CURL_COMMON="-fsS --connect-timeout 2 --max-time 10"
shift || true

json_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

case "$cmd" in
  status)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/status"
    ;;
  apps)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/apps"
    ;;
  resources)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/system/resources"
    ;;
  media)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/media/now-playing"
    ;;
  art)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/media/art"
    ;;
  notifications)
    curl $CURL_COMMON -H "Authorization: Bearer $TOKEN" "$BASE/v1/notifications"
    ;;
  brightness)
    if [ "$#" -gt 0 ]; then
      curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
        --data "{\"brightness\":$1}" "$BASE/v1/system/brightness"
    else
      curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" "$BASE/v1/system/brightness"
    fi
    ;;
  volume)
    if [ "$#" -gt 1 ]; then
      curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
        --data "{\"volume\":$1,\"stream\":$2}" "$BASE/v1/system/volume"
    elif [ "$#" -gt 0 ]; then
      curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
        --data "{\"volume\":$1}" "$BASE/v1/system/volume"
    else
      curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" "$BASE/v1/system/volume"
    fi
    ;;
  exec)
    [ "$#" -gt 0 ] || { print_exec_help >&2; exit 2; }
    CMD_ESCAPED=$(json_escape "$*")
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
      --data "{\"command\":\"$CMD_ESCAPED\"}" "$BASE/v1/exec"
    ;;
  permission)
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" "$BASE/v1/privileged/request-permission"
    ;;
  lock)
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" "$BASE/v1/screen/lock"
    ;;
  token)
    sub="${1:-}"; shift || true
    [ "$sub" = "rotate" ] || { echo "usage: launcherctl token rotate" >&2; exit 2; }
    curl $CURL_COMMON -X POST -H "Authorization: Bearer $TOKEN" "$BASE/v1/auth/rotate"
    ;;
  *)
    echo "launcherctl: unknown command: $cmd" >&2
    echo "run: launcherctl --help" >&2
    exit 2
    ;;
esac
