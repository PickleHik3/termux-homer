#!/data/data/com.termux/files/usr/bin/sh
set -eu

if [ "$#" != "0" ]; then
  echo "usage: launcher-restart" >&2
  exit 2
fi

# Keep behavior aligned with tel-restart for launcher state cleanup when present.
if command -v tel-delete-status >/dev/null 2>&1; then
  tel-delete-status -1 || true
fi

# Preferred path: exported app restart broadcast.
if cmd package query-receivers --brief --user 0 -a com.termux.app.restart -p com.termux 2>/dev/null | grep -qv '^No receivers found$'; then
  if am broadcast -a com.termux.app.restart -p com.termux >/dev/null 2>&1; then
    exit 0
  fi
fi

# Fallbacks for older app builds without the restart receiver.
RESTART_CMD='am start -S -n com.termux/.app.TermuxActivity'
if $RESTART_CMD >/dev/null 2>&1; then
  exit 0
fi

if command -v launcherctl >/dev/null 2>&1; then
  if launcherctl exec "$RESTART_CMD" >/dev/null 2>&1; then
    exit 0
  fi
fi

if [ -x "$HOME/.rish/rish" ]; then
  exec "$HOME/.rish/rish" -c "$RESTART_CMD"
fi

echo "launcher-restart: failed (restart broadcast and fallback launch paths failed)" >&2
exit 1
